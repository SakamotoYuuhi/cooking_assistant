# ---------------------------------------------------------------
# ローカル開発環境用 (.env にコピーして使用)
# EC2 本番環境では AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY を
# 設定せず、EC2 インスタンスの IAM ロールに権限を付与してください。
# ---------------------------------------------------------------

# ローカル開発時のみ設定（EC2 では IAM ロールを使うため不要）
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

AWS_DEFAULT_REGION=ap-northeast-1
S3_BUCKET_NAME=your_bucket_name_here
S3_RECIPES_PREFIX=cooking-assistant/recipes/
DYNAMODB_TABLE_NAME=cooking-assistant-sessions

# CloudWatch Logs（省略時はロギングをスキップ）
# CLOUDWATCH_LOG_GROUP=/cooking-assistant/app

# S3 → Lambda → EC2 インデックス自動再構築用 APIキー
# ランダムな文字列を設定（Lambda の環境変数にも同じ値を設定すること）
# REBUILD_API_KEY=your-secret-key-here
